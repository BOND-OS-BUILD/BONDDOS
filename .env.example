# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string. Use docker-compose.yml for a local instance:
#   docker compose up -d postgres
DATABASE_URL="postgresql://bondos:bondos@localhost:5432/bondos?schema=public"

# ── Auth (Better Auth) ──────────────────────────────────────────────────────
# Random 32+ char secret used to sign sessions. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-random-32-char-secret"
# Legacy alias kept for compatibility if this project ever moves to Auth.js.
NEXTAUTH_SECRET="replace-with-a-random-32-char-secret"

# Base URL the app is served from (no trailing slash).
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Storage (Supabase) ──────────────────────────────────────────────────────
SUPABASE_URL=""
SUPABASE_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Cache (Redis) ───────────────────────────────────────────────────────────
# Optional. Leave unset to fall back to the in-memory cache/rate-limiter —
# fine for local dev and single-instance deploys. Set to enable Redis-backed
# caching (see docker-compose.yml for a local instance).
REDIS_URL=""

# ── Email (password reset) ──────────────────────────────────────────────────
# Optional. Leave unset to log outgoing emails to the console instead of
# sending them — useful for local development.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="BOND OS <noreply@bondos.dev>"

# ── AI Memory & Retrieval (Phase 4) ─────────────────────────────────────────
# Embeddings: optional. Leave EMBEDDING_PROVIDER unset (or "LOCAL") to use the
# zero-config deterministic local fallback — no API key needed to boot, the
# same "always have a working default" pattern as REDIS_URL above. Set it to
# OPENAI/GEMINI/VOYAGE/OLLAMA to use a real embedding model instead (and set
# the matching key/URL below). See docs/embeddings.md.
EMBEDDING_PROVIDER="LOCAL"
EMBEDDING_MODEL=""
EMBEDDING_DIMENSIONS="1536"
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL=""
GEMINI_API_KEY=""
VOYAGE_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# AI generation: optional — nothing in this phase calls generate()/stream(),
# only listModels()/health() (the AI Settings page) and countTokens() (the
# Context Builder), so this can stay unset for now. See docs/ai-service.md.
AI_PROVIDER=""
AI_MODEL=""
ANTHROPIC_API_KEY=""
AI_TEMPERATURE="0.7"
AI_MAX_TOKENS="2048"
CONTEXT_TOKEN_BUDGET="8000"

# NODE_ENV is intentionally NOT set here — Next.js/Node set it contextually
# (development for `next dev`, production for `next build`/`next start`).
# Setting it in a loaded .env file overrides that and breaks the production
# build (Next.js will warn: "non-standard NODE_ENV value").
