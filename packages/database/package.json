{
  "name": "@bond-os/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, generated client, and seed script for BOND OS.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "validate": "dotenv -e ../../.env -- prisma validate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:diff:init": "dotenv -e ../../.env -- prisma migrate diff --from-empty --to-schema-datamodel=prisma/schema.prisma --script",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@bond-os/embeddings": "workspace:*",
    "@bond-os/shared": "workspace:*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@bond-os/config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
